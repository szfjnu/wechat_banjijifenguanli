{
  "name": "point_record",
  "title": "积分记录",
  "schemas": [
    {
      "name": "record_id",
      "title": "记录ID",
      "type": "String"
    },
    {
      "name": "record_date",
      "title": "记录日期时间",
      "type": "DateTime",
      "format": "string"
    },
    {
      "name": "item_id",
      "title": "积分项目ID",
      "type": "Number"
    },
    {
      "name": "item_name",
      "title": "积分项目名称",
      "type": "String"
    },
    {
      "name": "item_category",
      "title": "积分项目分类",
      "type": "String"
    },
    {
      "name": "point_type",
      "title": "积分类型",
      "type": "String"
    },
    {
      "name": "point_change",
      "title": "积分变化量",
      "type": "Number"
    },
    {
      "name": "student_id",
      "title": "关联学生ID",
      "type": "String"
    },
    {
      "name": "student_name",
      "title": "学生姓名",
      "type": "String"
    },
    {
      "name": "student_id_number",
      "title": "学号",
      "type": "String"
    },
    {
      "name": "score_before",
      "title": "变化前积分",
      "type": "Number"
    },
    {
      "name": "score_after",
      "title": "变化后积分",
      "type": "Number"
    },
    {
      "name": "reason",
      "title": "积分变化原因",
      "type": "MultiLineString"
    },
    {
      "name": "status",
      "title": "记录状态",
      "type": "String"
    },
    {
      "name": "operator_name",
      "title": "操作人姓名",
      "type": "String"
    },
    {
      "name": "operator_type",
      "title": "操作人类型",
      "type": "String"
    },
    {
      "name": "semester_id",
      "title": "关联学期ID",
      "type": "Number"
    },
    {
      "name": "semester_name",
      "title": "学期名称",
      "type": "String"
    },
    {
      "name": "remark",
      "title": "备注",
      "type": "MultiLineString"
    }
  ]
}
      "title": "周数",
      "type": "Number"
    },
    {
      "name": "status",
      "title": "完成状态",
      "type": "String"
    },
    {
      "name": "score",
      "title": "任务评分",
      "type": "Number"
    },
    {
      "name": "comment",
      "title": "评价备注",
      "type": "MultiLineString"
    },
    {
      "name": "images",
      "title": "证据图片",
      "type": "Array",
      "items": {
        "type": "String"
      }
    },
    {
      "name": "is_custom",
      "title": "是否自定义",
      "type": "Boolean"
    },
    {
      "name": "reminder_sent",
      "title": "已发送提醒",
      "type": "Boolean"
    }
  ]
}